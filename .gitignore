## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]in/
[Oo]bj/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/

# Rider
.idea/

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# NuGet
*.nupkg
packages/
!packages/build/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Test results
TestResults/
*.trx

# Dotnet CLI
project.lock.json
project.fragment.lock.json
artifacts/

# Environment files
.env
.env.*

# Publish folder
publish/

# Azure
*.azurePubxml